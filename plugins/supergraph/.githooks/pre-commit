#!/bin/bash
# Pre-commit hook for team members not using Claude Code
# Setup: chmod +x .githooks/pre-commit && git config core.hooksPath .githooks

echo "🔍 Running pre-commit checks..."

# Detect project and run tests
if [ -f "package.json" ]; then
    echo "  Detected: Node.js"
    npm test || { echo "❌ Tests failed"; exit 1; }
    if grep -q '"lint"' package.json 2>/dev/null; then
        npm run lint || { echo "❌ Lint failed"; exit 1; }
    fi
elif [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    echo "  Detected: Python"
    python -m pytest || pytest || { echo "❌ Tests failed"; exit 1; }
    if command -v ruff &>/dev/null; then
        ruff check . || { echo "❌ Lint failed"; exit 1; }
    fi
elif [ -f "go.mod" ]; then
    echo "  Detected: Go"
    go test ./... || { echo "❌ Tests failed"; exit 1; }
    if command -v golangci-lint &>/dev/null; then
        golangci-lint run || { echo "❌ Lint failed"; exit 1; }
    fi
elif [ -f "Cargo.toml" ]; then
    echo "  Detected: Rust"
    cargo test || { echo "❌ Tests failed"; exit 1; }
    cargo clippy -- -D warnings || { echo "❌ Clippy failed"; exit 1; }
elif [ -f "pubspec.yaml" ]; then
    echo "  Detected: Flutter"
    flutter test || { echo "❌ Tests failed"; exit 1; }
    flutter analyze || { echo "❌ Analyze failed"; exit 1; }
elif [ -f "composer.json" ]; then
    echo "  Detected: PHP"
    vendor/bin/phpunit || vendor/bin/pest || { echo "❌ Tests failed"; exit 1; }
fi

# Enforce provider migration and active-scope invariants.
bash plugins/supergraph/tests/test-codebase-memory-migration.sh || {
    echo "❌ Codebase Memory migration validation failed"
    exit 1
}

echo "✅ Pre-commit checks passed"
